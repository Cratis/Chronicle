{
    "name": "workbench",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite --config .frontend/vite.config.ts",
        "build": "vite build --config .frontend/vite.config.ts",
        "lint": "eslint --cache --quiet --fix",
        "lint:ci": "eslint --cache --quiet",
        "test": "vitest run --config .frontend/vite.config.ts",
        "test:watch": "vitest --watch --config .frontend/vite.config.ts",
        "ci": "cd $INIT_CWD && yarn test && yarn lint:ci && tsc -b .frontend/tsconfig.json && tsc -p .frontend/tsconfig.specs.json",
        "up": "cd $INIT_CWD && ncu -u \\!'@cratis/*'",
        "preview": "vite preview --config .frontend/vite.config.ts",
        "dev:storybook": "storybook dev -c .frontend/.storybook -p 6006",
        "build-storybook": "storybook build -c .frontend/.storybook"
    },
    "dependencies": {
        "@cratis/arc.react": "^20.8.2",
        "@cratis/arc.react.mvvm": "^20.8.2",
        "@cratis/arc.vite": "^20.8.2",
        "@cratis/components": "^1.6.9",
        "@monaco-editor/react": "^4.7.0",
        "allotment": "^1.20.5",
        "chart.js": "^4.5.1",
        "echarts": "^6.0.0",
        "monaco-editor": "^0.55.1",
        "pluralize": "^8.0.0",
        "primeicons": "^7.0.0",
        "primereact": "^10.9.7",
        "react-icons": "^5.6.0",
        "ts-deepmerge": "7.0.3",
        "usehooks-ts": "3.1.1"
    },
    "devDependencies": {
        "@eslint/eslintrc": "3.3.5",
        "@eslint/js": "10.0.1",
        "@storybook/react": "^10.3.5",
        "@storybook/react-vite": "^10.3.5",
        "@tailwindcss/postcss": "4.2.2",
        "@tailwindcss/vite": "4.2.2",
        "@tony.ganchev/eslint-plugin-header": "^3.4.3",
        "@types/chai": "5.2.3",
        "@types/chai-as-promised": "8.0.2",
        "@types/mocha": "10.0.10",
        "@types/node": "25.6.0",
        "@types/pluralize": "0.0.33",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@types/sinon": "21.0.1",
        "@types/sinon-chai": "4.0.0",
        "@typescript-eslint/eslint-plugin": "8.58.2",
        "@typescript-eslint/parser": "8.58.2",
        "@vitejs/plugin-react": "6.0.1",
        "@vitest/coverage-v8": "4.1.4",
        "autoprefixer": "10.5.0",
        "chai": "6.2.2",
        "chai-as-promised": "8.0.2",
        "eslint": "10.2.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-no-null": "1.0.2",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-react-refresh": "0.5.2",
        "globals": "17.5.0",
        "hash-files": "1.1.1",
        "mocha": "11.7.5",
        "prettier": "3.8.2",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "react-router-dom": "7.14.1",
        "sinon": "21.1.2",
        "sinon-chai": "4.0.1",
        "storybook": "^10.3.5",
        "tailwindcss": "4.2.2",
        "ts-node": "10.9.2",
        "tsconfig-paths": "4.2.0",
        "typescript": "6.0.2",
        "typescript-eslint": "8.58.2",
        "vite": "8.0.8",
        "vite-plugin-commonjs": "0.10.4",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.1.4"
    },
    "resolutions": {
        "@cratis/arc.react": "^20.1.0",
        "@cratis/arc": "^20.1.0"
    },
    "packageManager": "yarn@4.5.3"
}
