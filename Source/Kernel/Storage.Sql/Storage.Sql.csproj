<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <AssemblyName>Cratis.Chronicle.Storage.Sql</AssemblyName>
        <RootNamespace>Cratis.Chronicle.Storage.Sql</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Orleans.Reminders" />
        <PackageReference Include="AspNetCore.HealthChecks.NpgSql" />
        <PackageReference Include="AspNetCore.HealthChecks.SqlServer" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="../Core/Core.csproj" />
        <ProjectReference Include="../Storage/Storage.csproj" />
        <ProjectReference Include="../Concepts/Concepts.csproj">
            <PrivateAssets>all</PrivateAssets>
        </ProjectReference>
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="Cratis.Arc" />
      <PackageReference Include="Cratis.Arc.EntityFrameworkCore" />
      <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
      <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" />
      <!-- Override the vulnerable native SQLite library (GHSA-2m69-gcr7-jv3q) pulled in transitively by EF Core Sqlite. -->
      <PackageReference Include="SQLitePCLRaw.lib.e_sqlite3" />
      <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" />
      <PackageReference Include="Microsoft.Data.SqlClient" />
      <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" />
    </ItemGroup>
</Project>
