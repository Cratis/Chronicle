<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <TargetFrameworks></TargetFrameworks>
        <AssemblyName>Cratis.Chronicle.Testing</AssemblyName>
        <RootNamespace>Cratis.Chronicle.Testing</RootNamespace>
        <IsTestProject>false</IsTestProject>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="../DotNET/DotNET.csproj"/>
        <ProjectReference Include="../Connections/Connections.csproj" />
        <ProjectReference Include="../../Infrastructure/Infrastructure.csproj">
            <PrivateAssets>all</PrivateAssets>
        </ProjectReference>
        <ProjectReference Include="../../Kernel/Contracts/Contracts.csproj">
            <PrivateAssets>all</PrivateAssets>
        </ProjectReference>
        <ProjectReference Include="../../Kernel/Concepts/Concepts.csproj">
            <Aliases>KernelConcepts</Aliases>
            <PrivateAssets>all</PrivateAssets>
        </ProjectReference>
        <ProjectReference Include="../../Kernel/Core/Core.csproj">
            <Aliases>KernelCore</Aliases>
            <PrivateAssets>all</PrivateAssets>
        </ProjectReference>
        <ProjectReference Include="../../Kernel/Storage/Storage.csproj">
            <PrivateAssets>all</PrivateAssets>
        </ProjectReference>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging" />
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
        <!-- <PackageReference Include="Microsoft.Orleans.BroadcastChannel" PrivateAssets="all"/>
        <PackageReference Include="Microsoft.Orleans.Sdk" PrivateAssets="all"/>
        <PackageReference Include="Microsoft.Orleans.Server" PrivateAssets="all"/>
        <PackageReference Include="Microsoft.Orleans.Reminders" PrivateAssets="all"/>
        <PackageReference Include="Microsoft.Orleans.Streaming" PrivateAssets="all"/>
        <PackageReference Include="Microsoft.Orleans.Serialization.SystemTextJson" PrivateAssets="all"/> -->
        <PackageReference Include="xunit">
            <PrivateAssets>all</PrivateAssets>
        </PackageReference>
    </ItemGroup>

    <!-- Pack Orleans runtime assemblies into lib/ so they are available without nuspec dependencies -->
    <PropertyGroup>
        <PrivatePackageRuntimeAssemblyRegex>^Orleans\..*\.dll$</PrivatePackageRuntimeAssemblyRegex>
    </PropertyGroup>

</Project>
